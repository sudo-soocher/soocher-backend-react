{
    "extends": [
        "react-app",
        "react-app/jest"
    ],
    "rules": {
        "no-unused-vars": "warn",
        "react-hooks/exhaustive-deps": "warn",
        "default-case": "warn",
        "jsx-a11y/role-has-required-aria-props": "warn",
        "jsx-a11y/heading-has-content": "warn",
        "import/no-anonymous-default-export": "warn"
    }
}